{
    "name": "dot-anything",
    "displayName": "Dot Anything",
    "description": "%extension.description%",
    "publisher": "lqzh",
    "author": {
        "name": "lqzh"
    },
    "version": "1.5.0",
    "icon": "public/logo_128.png",
    "galleryBanner": {
        "color": "#0D1117",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.103.0"
    },
    "categories": [
        "Snippets",
        "Formatters"
    ],
    "keywords": [
        "Snippets",
        "Formatters",
        "convert",
        "transform",
        "template"
    ],
    "pricing": "Free",
    "activationEvents": [
        "onStartupFinished"
    ],
    "sponsor": {
        "url": "https://github.com/sponsors/lqzhgood"
    },
    "l10n": "./l10n",
    "main": "./dist/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "npm run check-types && npm run lint && node esbuild.js --production",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-types": "tsc --noEmit",
        "lint": "eslint src",
        "test": "vscode-test",
        "build": "npx @vscode/vsce package"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "25.x",
        "@types/vscode": "^1.103.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "esbuild": "^0.27.3",
        "eslint": "^10.0.2",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3"
    },
    "license": "SEE LICENSE IN LICENSE.txt",
    "bugs": {
        "url": "https://github.com/lqzhgood/vscode-ext-dot-anything/issues",
        "email": "i@lqzh.me"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/lqzhgood/vscode-ext-dot-anything.git"
    },
    "homepage": "https://github.com/lqzhgood/vscode-ext-dot-anything/blob/main/README.md",
    "contributes": {
        "configuration": {
            "title": "%config.title%",
            "properties": {
                "dot-anything.debug": {
                    "type": "boolean",
                    "description": "%config.debug.description%",
                    "default": false
                },
                "dot-anything.rules": {
                    "type": "array",
                    "markdownDescription": "%config.rules.description%",
                    "default": [
                        {
                            "trigger": "log",
                            "description": "console.log",
                            "snippet": "console.log('🖨️ #filePath#[#lineNumber#:#column#] #word^toKebabCase#:', #word#);"
                        },
                        {
                            "trigger": "//",
                            "description": "Single-line comment",
                            "replaceMode": "line",
                            "pattern": "",
                            "snippet": "// #lineText#"
                        }
                    ],
                    "items": {
                        "type": "object",
                        "properties": {
                            "fileType": {
                                "anyOf": [
                                    {
                                        "type": "string",
                                        "enum": [
                                            "*",
                                            "abap",
                                            "bat",
                                            "bibtex",
                                            "clojure",
                                            "coffeescript",
                                            "c",
                                            "cpp",
                                            "csharp",
                                            "dockercompose",
                                            "css",
                                            "cuda-cpp",
                                            "d",
                                            "dart",
                                            "pascal",
                                            "diff",
                                            "dockerfile",
                                            "erlang",
                                            "fsharp",
                                            "git-commit",
                                            "git-rebase",
                                            "go",
                                            "groovy",
                                            "handlebars",
                                            "haml",
                                            "haskell",
                                            "html",
                                            "ini",
                                            "java",
                                            "javascript",
                                            "javascriptreact",
                                            "json",
                                            "jsonc",
                                            "julia",
                                            "latex",
                                            "less",
                                            "lua",
                                            "makefile",
                                            "markdown",
                                            "objective-c",
                                            "objective-cpp",
                                            "ocaml",
                                            "perl",
                                            "perl6",
                                            "php",
                                            "plaintext",
                                            "powershell",
                                            "jade",
                                            "pug",
                                            "python",
                                            "r",
                                            "razor",
                                            "ruby",
                                            "rust",
                                            "scss",
                                            "sass",
                                            "shaderlab",
                                            "shellscript",
                                            "slim",
                                            "sql",
                                            "stylus",
                                            "svelte",
                                            "swift",
                                            "typescript",
                                            "typescriptreact",
                                            "tex",
                                            "vb",
                                            "vue",
                                            "vue-html",
                                            "xml",
                                            "xsl",
                                            "yaml"
                                        ],
                                        "default": "*"
                                    },
                                    {
                                        "type": "array",
                                        "items": {
                                            "type": "string",
                                            "enum": [
                                                "*",
                                                "abap",
                                                "bat",
                                                "bibtex",
                                                "clojure",
                                                "coffeescript",
                                                "c",
                                                "cpp",
                                                "csharp",
                                                "dockercompose",
                                                "css",
                                                "cuda-cpp",
                                                "d",
                                                "dart",
                                                "pascal",
                                                "diff",
                                                "dockerfile",
                                                "erlang",
                                                "fsharp",
                                                "git-commit",
                                                "git-rebase",
                                                "go",
                                                "groovy",
                                                "handlebars",
                                                "haml",
                                                "haskell",
                                                "html",
                                                "ini",
                                                "java",
                                                "javascript",
                                                "javascriptreact",
                                                "json",
                                                "jsonc",
                                                "julia",
                                                "latex",
                                                "less",
                                                "lua",
                                                "makefile",
                                                "markdown",
                                                "objective-c",
                                                "objective-cpp",
                                                "ocaml",
                                                "perl",
                                                "perl6",
                                                "php",
                                                "plaintext",
                                                "powershell",
                                                "jade",
                                                "pug",
                                                "python",
                                                "r",
                                                "razor",
                                                "ruby",
                                                "rust",
                                                "scss",
                                                "sass",
                                                "shaderlab",
                                                "shellscript",
                                                "slim",
                                                "sql",
                                                "stylus",
                                                "svelte",
                                                "swift",
                                                "typescript",
                                                "typescriptreact",
                                                "tex",
                                                "vb",
                                                "vue",
                                                "vue-html",
                                                "xml",
                                                "xsl",
                                                "yaml"
                                            ],
                                            "default": "*"
                                        }
                                    }
                                ],
                                "description": "%config.rules.fileType.description%"
                            },
                            "trigger": {
                                "type": "string",
                                "required": true,
                                "description": "%config.rules.trigger.description%"
                            },
                            "description": {
                                "type": "string",
                                "required": true,
                                "description": "%config.rules.ruleDescription.description%"
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "function",
                                    "text"
                                ],
                                "default": "text",
                                "description": "%config.rules.type.description%"
                            },
                            "snippet": {
                                "anyOf": [
                                    {
                                        "type": "string"
                                    },
                                    {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                ],
                                "description": "%config.rules.snippet.description%"
                            },
                            "replaceMode": {
                                "type": "string",
                                "enum": [
                                    "word",
                                    "line",
                                    "file"
                                ],
                                "default": "word",
                                "description": "%config.rules.replaceMode.description%"
                            },
                            "pattern": {
                                "type": "string",
                                "description": "%config.rules.pattern.description%"
                            }
                        }
                    }
                },
                "dot-anything.fns": {
                    "type": "array",
                    "description": "%config.fns.description%",
                    "default": [],
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "%config.fns.name.description%"
                            },
                            "fn": {
                                "type": "string",
                                "description": "%config.fns.fn.description%"
                            }
                        },
                        "required": [
                            "name",
                            "fn"
                        ]
                    }
                }
            }
        }
    }
}
